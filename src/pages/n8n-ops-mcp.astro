---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../lib/tools.ts';
import {
  softwareApplicationLd,
  organizationLd,
  absoluteImage,
  graph,
} from '../lib/seo.ts';

const tool = TOOLS.find((t) => t.slug === 'n8n-ops-mcp')!;

const title = 'n8n-ops-mcp - run n8n ops from your AI client';
const description =
  'n8n-ops-mcp is an ops-focused MCP server for n8n: list, inspect, trigger, validate, and audit workflows from any MCP client, with auto-backup and confirm gates on destructive writes.';

const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name: tool.name,
    siteUrl: 'https://lidless.dev/n8n-ops-mcp',
    description,
    image: absoluteImage('https://lidless.dev', '/og-card.png'),
    codeRepository: tool.repo,
    license: 'https://opensource.org/licenses/MIT',
  }),
]);

const badgeClass =
  tool.lifecycle === 'Active'
    ? 'badge badge-active'
    : tool.lifecycle === 'WIP'
      ? 'badge badge-wip'
      : 'badge badge-experimental';

const readTools = [
  { name: 'n8n_list_workflows', desc: 'List workflows; filter by active / tags / name.' },
  { name: 'n8n_get_workflow', desc: 'Fetch one workflow, optionally with the full node graph.' },
  { name: 'n8n_list_executions', desc: 'List recent executions; filter by workflow / status.' },
  { name: 'n8n_get_execution', desc: 'Fetch an execution with per-node run log + raw error.' },
  { name: 'n8n_search_executions', desc: 'Text-search recent executions for an error fragment.' },
  { name: 'n8n_list_webhooks', desc: 'Enumerate webhook + form-trigger URLs.' },
  { name: 'n8n_validate_workflow', desc: 'Static checks: deprecated nodes, legacy Code API, orphans.' },
  { name: 'n8n_diff_workflow', desc: 'Semantic diff a workflow against a snapshot file or object.' },
  { name: 'n8n_list_schedules', desc: 'List schedule triggers with human-readable descriptions.' },
  { name: 'n8n_execution_stats', desc: 'Per-workflow counts, failure rate, avg + p95 runtime.' },
  { name: 'n8n_run_audit', desc: "Run n8n's built-in security audit (admin/owner key)." },
  { name: 'n8n_find_workflows_using_node_type', desc: 'Find every workflow using a given node type.' },
  { name: 'n8n_find_workflows_using_credential', desc: 'Credential rotation / blast-radius scanner.' },
  { name: 'n8n_check_disabled_nodes', desc: 'Surface disabled nodes the n8n UI does not list.' },
  { name: 'n8n_list_tags / n8n_get_workflow_tags', desc: 'Read tags and a workflow’s tag set.' },
  { name: 'n8n_list_credentials / n8n_get_credential_schema', desc: 'Credential metadata + type schema (secrets never echoed).' },
  { name: 'n8n_audit_browser_bridge_usage', desc: 'Find workflows that call the browser-bridge CLI.' },
  { name: 'n8n_scaffold_browser_bridge_node', desc: 'Generate a ready-to-paste browser-bridge node (local).' },
];

const writeTools = [
  { name: 'n8n_trigger', desc: 'Run a workflow via webhook or workflow-id (confirm-gated).' },
  { name: 'n8n_create_workflow', desc: 'Create a workflow; dry-run preview without confirm.' },
  { name: 'n8n_save_workflow', desc: 'Overwrite a workflow with auto-backup + validation.' },
  { name: 'n8n_activate / n8n_deactivate', desc: 'Arm or halt a workflow’s triggers (confirm-gated).' },
  { name: 'n8n_archive_workflow / n8n_unarchive_workflow', desc: 'Reversible soft-delete and restore.' },
  { name: 'n8n_delete_workflow', desc: 'Permanent delete with snapshot-before-delete.' },
  { name: 'n8n_cancel_execution / n8n_retry_execution', desc: 'Stop or retry an execution by id.' },
  { name: 'n8n_delete_execution / n8n_delete_executions', desc: 'Delete one or up to 50 execution records.' },
  { name: 'n8n_retry_executions', desc: 'Batch retry executions (max 50, abort on 5xx).' },
  { name: 'n8n_pin_node_data / n8n_unpin_node_data', desc: 'Pin or clear sample data on a node for testing.' },
  { name: 'n8n_create_tag / n8n_delete_tag / n8n_set_workflow_tags', desc: 'Tag CRUD and workflow tag-set replace.' },
];

const credTools = [
  { name: 'n8n_create_credential', desc: 'Create a credential; secrets redacted from every response.' },
  { name: 'n8n_delete_credential', desc: 'Delete a credential (cascades to every referencing workflow).' },
];

const clientConfig = `{
  "mcpServers": {
    "n8n": {
      "command": "n8n-ops-mcp",
      "env": {
        "N8N_BASE_URL": "http://localhost:5678",
        "N8N_API_KEY": "your-api-key-here"
      }
    }
  }
}`;
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="px-6 md:px-10 py-12 max-w-4xl mx-auto">
    <!-- breadcrumb / back to hub -->
    <nav class="kicker mb-6" aria-label="Breadcrumb">
      <a href="/" style="text-decoration: none;">&larr; Lidless</a>
      <span style="color: var(--text-dim);"> / Network / {tool.name}</span>
    </nav>

    <!-- ============================ HERO ============================ -->
    <header class="mb-10">
      <div class="flex items-center gap-3 flex-wrap mb-3">
        <h1 class="wordmark text-4xl md:text-5xl uppercase m-0">{tool.name}</h1>
        <span class={badgeClass}>{tool.lifecycle}</span>
      </div>
      <p class="text-lg" style="color: var(--text-muted); max-width: 42rem;">
        {tool.oneLiner}
      </p>
      <div class="tool-cta">
        <a class="btn-primary" href={tool.repo} rel="noopener">GitHub repo &rarr;</a>
        {tool.npm
          ? <a class="btn-ghost" href={`https://www.npmjs.com/package/${tool.npm}`} rel="noopener">npm: {tool.npm} &rarr;</a>
          : <span class="cta-note">self-hosted &middot; run from source</span>}
      </div>
    </header>

    <!-- ============================ WHAT IT DOES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT DOES</h2></div>
      <div style="color: var(--text-muted); max-width: 46rem;">
        <p class="mb-4">
          n8n-ops-mcp is an ops-focused Model Context Protocol server for
          <a href="https://n8n.io/" rel="noopener" style="color: var(--accent);">n8n</a>. It lets an
          AI client answer "what's broken in my n8n?", trigger workflows from chat, audit for
          security risks, and safely edit workflows without you leaving the client. It targets the
          ops surface (list, trigger, validate, edit) rather than indexing n8n's node catalog.
        </p>
        <p class="mb-4">
          It was built for <a href="https://github.com/openclaw/openclaw" rel="noopener"
          style="color: var(--accent);">OpenClaw</a> as a first-class plugin and exposed as an MCP
          server for everyone else, so it works with Claude Desktop, Claude Code, Codex CLI, Cursor,
          Windsurf, or any other MCP host with no hard dependency on a specific model or harness.
        </p>
        <p>
          Writes are off by default. Destructive operations are confirm-gated, workflow deletes
          snapshot to a backup directory first, and credential writes sit behind a second
          independent gate. Credential secrets are stripped from every response, including error
          paths.
        </p>
      </div>
    </section>

    <!-- ============================ INSTALL ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">INSTALL</h2></div>
      <p class="mb-4" style="color: var(--text-muted);">
        Published to npm as <code class="font-mono" style="color: var(--accent);">n8n-ops-mcp</code>.
        Install the global binary, or run it on demand with <span class="font-mono">npx</span>.
        Requires Node.js 20+.
      </p>
      <div class="term" aria-label="Install command">
        <div><span class="prompt">$</span> npm install -g n8n-ops-mcp</div>
        <div><span class="prompt">$</span> npx n8n-ops-mcp <span style="color: var(--text-dim);"># run on demand</span></div>
      </div>
    </section>

    <!-- ============================ CAPABILITIES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CAPABILITIES / TOOLS EXPOSED</h2></div>

      <p class="cap-group-label">Reads &amp; scanners &middot; always available</p>
      <div class="cap-list">
        {readTools.map((t) => (
          <div class="cap">
            <div class="cap-name">{t.name}</div>
            <div class="cap-desc">{t.desc}</div>
          </div>
        ))}
      </div>

      <p class="cap-group-label">Writes &middot; hidden unless N8N_ENABLE_EDIT=true</p>
      <div class="cap-list">
        {writeTools.map((t) => (
          <div class="cap">
            <div class="cap-name">{t.name}</div>
            <div class="cap-desc">{t.desc}</div>
          </div>
        ))}
      </div>

      <p class="cap-group-label">Credential writes &middot; double-gated</p>
      <div class="cap-list">
        {credTools.map((t) => (
          <div class="cap">
            <div class="cap-name">{t.name}</div>
            <div class="cap-desc">{t.desc}</div>
          </div>
        ))}
      </div>
      <p class="text-sm mt-4" style="color: var(--text-dim);">
        Write tools require <code class="font-mono">N8N_ENABLE_EDIT=true</code>; credential writes
        require <code class="font-mono">N8N_ENABLE_CREDENTIALS_WRITE=true</code> on top of that. Full
        per-tool reference in the <a href={tool.repo} rel="noopener" style="color: var(--accent);">README</a>.
      </p>
    </section>

    <!-- ============================ CLIENT CONFIG ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CLIENT CONFIG</h2></div>
      <p class="mb-4" style="color: var(--text-muted);">
        Stdio transport. Generate an API key in n8n under <strong>Settings &rarr; API</strong>, then
        point any MCP host at the <span class="font-mono">n8n-ops-mcp</span> binary. Example
        <span class="font-mono">mcpServers</span> entry (Claude Desktop / Claude Code):
      </p>
      <pre class="term" aria-label="MCP client configuration"><code>{clientConfig}</code></pre>
      <p class="text-sm mt-3" style="color: var(--text-dim);">
        Required: <code class="font-mono">N8N_BASE_URL</code>,
        <code class="font-mono">N8N_API_KEY</code>. Optional:
        <code class="font-mono">N8N_ENABLE_EDIT</code>,
        <code class="font-mono">N8N_ENABLE_CREDENTIALS_WRITE</code>,
        <code class="font-mono">N8N_BACKUP_DIR</code>,
        <code class="font-mono">N8N_MAX_EXECUTION_LOG_BYTES</code>,
        <code class="font-mono">N8N_REQUEST_TIMEOUT_MS</code>. Also installs as a first-class
        OpenClaw plugin via <code class="font-mono">clawhub:n8n-ops-mcp</code>.
      </p>
    </section>
  </main>
</BaseLayout>
