---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../lib/tools.ts';
import {
  softwareApplicationLd,
  organizationLd,
  absoluteImage,
  graph,
} from '../lib/seo.ts';

const tool = TOOLS.find((t) => t.slug === 'eero-cli')!;

const title = 'eero-cli';
const description =
  'eero-cli is a small terminal CLI for managing devices on an eero mesh network: non-interactive SMS auth, filtered device listing, profiles and schedules, and single or bulk device blocking.';

const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name: tool.name,
    siteUrl: 'https://lidless.dev/eero-cli',
    description,
    image: absoluteImage('https://lidless.dev', '/og-card.png'),
    codeRepository: tool.repo,
    license: 'https://opensource.org/licenses/MIT',
  }),
]);

const badgeClass =
  tool.lifecycle === 'Active'
    ? 'badge badge-active'
    : tool.lifecycle === 'WIP'
      ? 'badge badge-wip'
      : 'badge badge-experimental';

// Commands as the README documents them.
const commandGroups: { group: string; items: { name: string; desc: string }[] }[] = [
  {
    group: 'Auth',
    items: [
      { name: 'eero auth <phone|email>', desc: 'Step 1: trigger the SMS or email login code (non-interactive).' },
      { name: 'eero auth --code 123456', desc: 'Step 2: verify the code within 30 minutes. Session token written to ~/.config/eero/session.json (mode 0600).' },
    ],
  },
  {
    group: 'Devices',
    items: [
      { name: 'eero devices', desc: 'List everything on the network.' },
      { name: 'eero devices --filter / --search', desc: 'Regex over nickname/hostname, or plain-text over name, host, manufacturer, MAC, IP, URL.' },
      { name: 'eero devices --mac / --online / --offline', desc: 'Filter by MAC prefix, or by current connection state.' },
    ],
  },
  {
    group: 'Profiles',
    items: [
      { name: 'eero profiles --devices', desc: 'List profiles and the devices assigned to each.' },
      { name: 'eero profile-create / profile-assign', desc: 'Create a dedicated profile, then assign devices to it.' },
      { name: 'eero profile-schedule / profile-block-apps', desc: 'Set profile-level pause schedules (start/end/days) and block apps.' },
    ],
  },
  {
    group: 'Blocking',
    items: [
      { name: 'eero block <mac-or-id> [--unblock]', desc: 'Block or unblock a device. Works on currently online devices.' },
      { name: 'eero block-cleanup <regex> [-y]', desc: 'Bulk-block matching offline devices; --include-online widens the net.' },
    ],
  },
];
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="px-6 md:px-10 py-12 max-w-4xl mx-auto">
    <!-- back-link / breadcrumb -->
    <nav class="kicker mb-8" aria-label="Breadcrumb">
      <a href="/" style="text-decoration: none;">&larr; Lidless</a>
      <span style="color: var(--text-dim);"> / NETWORK / EERO-CLI</span>
    </nav>

    <!-- ============================ HERO ============================ -->
    <header class="mb-10">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="wordmark font-display text-4xl md:text-5xl m-0">{tool.name}</h1>
        <span class={badgeClass}>{tool.lifecycle}</span>
      </div>
      <p class="text-lg mt-4 max-w-2xl" style="color: var(--text-muted);">{tool.oneLiner}</p>
      <div class="tool-cta">
        <a class="btn-primary" href={tool.repo} rel="noopener">GitHub repo &rarr;</a>
        {tool.npm
          ? <a class="btn-ghost" href={`https://www.npmjs.com/package/${tool.npm}`} rel="noopener">npm: {tool.npm} &rarr;</a>
          : <span class="cta-note">self-hosted &middot; run from source</span>}
      </div>
      <div class="spec-strip mt-7 max-w-2xl text-left">
        <div class="spec"><div class="n">CLI</div><div class="l">terminal tool, not an MCP server</div></div>
        <div class="spec"><div class="n">Py 3.12+</div><div class="l">runtime</div></div>
        <div class="spec"><div class="n">MIT</div><div class="l">open source</div></div>
      </div>
    </header>

    <!-- ============================ WHAT IT DOES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT DOES</h2></div>
      <p class="max-w-2xl" style="color: var(--text-muted);">
        eero-cli is a tiny terminal CLI for managing devices on an eero mesh network from a real
        shell. It wraps
        <a href="https://github.com/fulviofreitas/eero-api" rel="noopener" style="color: var(--accent);">eero-api</a>
        (the most actively maintained reverse-engineered Python client) and adds a two-step,
        non-interactive SMS/email auth flow that survives across separate shell invocations,
        filtered device listing, profile and schedule management, and single or bulk device
        blocking. The two-step auth is deliberately non-interactive so it works in wrappers that
        cannot drive an interactive prompt, like a scripted setup or an agent's shell.
      </p>
      <p class="max-w-2xl mt-4 text-sm" style="color: var(--warn);">
        Status: experimental. eero has no public API; this rides on a reverse-engineered library,
        so behavior can change when eero changes their backend. It is a CLI, not an MCP server,
        so there is no AI-client config block.
      </p>
    </section>

    <!-- ============================ INSTALL ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">INSTALL</h2></div>
      <p class="max-w-2xl mb-4" style="color: var(--text-muted);">
        Not published to a package index. Install straight from the GitHub repo with
        <span class="font-mono">pipx</span>, or from a local clone. Requires Python 3.12+
        (inherited from <span class="font-mono">eero-api</span>).
      </p>
      <div class="term" aria-label="Install eero-cli with pipx">
        <div><span class="prompt">$</span> pipx install git+https://github.com/solomonneas/eero-cli</div>
        <div>&nbsp;</div>
        <div><span style="color: var(--text-dim);"># or, from a clone</span></div>
        <div><span class="prompt">$</span> pipx install .</div>
      </div>
    </section>

    <!-- ============================ FIRST-TIME AUTH ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">FIRST-TIME AUTH</h2></div>
      <p class="max-w-2xl mb-4" style="color: var(--text-muted);">
        The eero API uses a two-step SMS/email login. Both halves are non-interactive so they work
        in any wrapper that cannot drive an interactive prompt.
      </p>
      <div class="term" aria-label="Two-step eero auth">
        <div><span style="color: var(--text-dim);"># step 1: trigger the SMS / email</span></div>
        <div><span class="prompt">$</span> eero auth +15551234567        <span style="color: var(--text-dim);"># phone</span></div>
        <div><span class="prompt">$</span> eero auth you@example.com     <span style="color: var(--text-dim);"># or email</span></div>
        <div>&nbsp;</div>
        <div><span style="color: var(--text-dim);"># step 2: after the code arrives, within 30 minutes</span></div>
        <div><span class="prompt">$</span> eero auth --code 123456</div>
      </div>
      <p class="text-sm mt-4 max-w-2xl" style="color: var(--text-dim);">
        Session token is written to <span class="font-mono">~/.config/eero/session.json</span>
        (mode 0600). Re-run <span class="font-mono">eero auth</span> any time to start over.
      </p>
    </section>

    <!-- ============================ COMMANDS ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">COMMANDS</h2></div>
      {commandGroups.map((g) => (
        <>
          <p class="cap-group-label">{g.group}</p>
          <div class="cap-list">
            {g.items.map((c) => (
              <div class="cap">
                <div class="cap-name">{c.name}</div>
                <div class="cap-desc">{c.desc}</div>
              </div>
            ))}
          </div>
        </>
      ))}
    </section>

    <!-- ============================ LIMITS ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT CANNOT DO</h2></div>
      <p class="max-w-2xl" style="color: var(--text-muted);">
        The eero REST and GraphQL APIs do not expose any mutating operation that removes an offline
        device. This was verified end-to-end: the documented delete and forget calls return 404 or
        silently no-op, and none of the 215 GraphQL mutations in the eero web admin match a
        forget/delete/remove-device shape. To actually forget a stale device, use the eero mobile
        app (or just wait, eero auto-culls truly stale entries after about 30 days). The README
        documents the full investigation so you do not have to repeat it.
      </p>
    </section>
  </main>
</BaseLayout>
