---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS, type Lifecycle } from '../lib/tools.ts';
import {
  composeTitle,
  softwareApplicationLd,
  organizationLd,
  absoluteImage,
  graph,
} from '../lib/seo.ts';

// Look up this tool by slug so name/lifecycle/repo/npm stay in sync with the hub grid.
const tool = TOOLS.find((t) => t.slug === 'mitre-mcp')!;
const { name, oneLiner, lifecycle, repo, npm } = tool;

const SITE_URL = 'https://lidless.dev';
const pageUrl = `${SITE_URL}/mitre-mcp`;

const title = composeTitle('MITRE ATT&CK MCP server', 'technique lookup for AI agents');
const description =
  'mitre-mcp is an open-source MCP server for MITRE ATT&CK: 39 tools to look up techniques, map alerts, profile campaigns, export Navigator layers, and correlate across your SOC.';

const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name,
    siteUrl: pageUrl,
    description,
    image: absoluteImage(SITE_URL, '/og-card.png'),
    codeRepository: repo,
    license: 'https://opensource.org/licenses/MIT',
  }),
]);

const badgeClass = (l: Lifecycle) =>
  l === 'Active'
    ? 'badge badge-active'
    : l === 'WIP'
    ? 'badge badge-wip'
    : 'badge badge-experimental';

// Tools exposed, grouped from the README's surface (39 total).
const toolGroups: { group: string; tools: string[] }[] = [
  {
    group: 'Core ATT&CK (19)',
    tools: [
      'technique + tactic lookup and search',
      'threat group + software/malware intelligence',
      'mitigation mapping, detection coverage',
      'alert-to-technique mapping, attack paths, data version',
    ],
  },
  {
    group: 'Campaigns (4)',
    tools: [
      'campaign profile, get + list campaigns',
      'search campaigns by keyword or technique',
    ],
  },
  {
    group: 'Navigator (1)',
    tools: ['export ATT&CK Navigator JSON layers: coverage, group, campaign, diff'],
  },
  {
    group: 'Wazuh integration (4)',
    tools: [
      'manager status, map alerts to techniques',
      'rule coverage, ATT&CK-enriched alerts',
    ],
  },
  {
    group: 'TheHive + Cortex (5)',
    tools: [
      'enrich, create, list TheHive cases with ATT&CK context',
      'Cortex analyzer coverage + run analyzers',
    ],
  },
  {
    group: 'MISP + cross-stack (6)',
    tools: [
      'map events, search IOCs, create + list MISP events',
      'SOC connection status, cross-platform correlation',
    ],
  },
];
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="px-6 md:px-10 py-12 max-w-4xl mx-auto">
    <!-- breadcrumb / back to hub -->
    <p class="kicker mb-6">
      <a href="/" style="color: var(--text-dim); text-decoration: none;">&larr; Lidless</a>
      &nbsp;/&nbsp; SECURITY / SOC &nbsp;/&nbsp; {name}
    </p>

    <!-- ============================ HERO ============================ -->
    <header class="mb-10">
      <div class="flex items-center gap-3 flex-wrap mb-3">
        <h1 class="wordmark font-display text-4xl md:text-5xl uppercase m-0">{name}</h1>
        <span class={badgeClass(lifecycle)}>{lifecycle}</span>
      </div>
      <p class="text-lg max-w-2xl" style="color: var(--text-muted);">{oneLiner}</p>
      <div class="tool-cta">
        <a class="btn-primary" href={tool.repo} rel="noopener">GitHub repo &rarr;</a>
        {tool.npm
          ? <a class="btn-ghost" href={`https://www.npmjs.com/package/${tool.npm}`} rel="noopener">npm: {tool.npm} &rarr;</a>
          : <span class="cta-note">self-hosted &middot; run from source</span>}
      </div>
    </header>

    <!-- ============================ WHAT IT DOES ============================ -->
    <section class="mb-12">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT DOES</h2></div>
      <div class="max-w-2xl" style="color: var(--text-muted);">
        <p class="mb-4">
          mitre-mcp is a Model Context Protocol server that gives an AI client comprehensive access
          to the
          <a href="https://attack.mitre.org/" rel="noopener" style="color: var(--accent);">MITRE ATT&amp;CK</a>
          knowledge base. Look up techniques and tactics, map alerts to ATT&amp;CK, analyze detection
          coverage, profile campaigns, and generate ATT&amp;CK Navigator layers.
        </p>
        <p class="mb-4">
          It exposes 39 tools, 3 resources, and 4 prompts, with optional SOC integration that
          correlates techniques across Wazuh, TheHive, Cortex, and MISP simultaneously. ATT&amp;CK
          data is sourced from the official STIX 2.1 bundles (Enterprise, Mobile, and ICS), cached
          locally, and so works offline after the first download.
        </p>
        <p>
          State-changing SOC tools default to a dry run: they report the action they would take
          without touching the platform unless you pass <span class="font-mono">confirm: true</span>
          or set <span class="font-mono">MITRE_SOC_ALLOW_WRITES=true</span>.
        </p>
      </div>
    </section>

    <!-- ============================ INSTALL ============================ -->
    <section class="mb-12">
      <div class="section-rule mb-5"><h2 class="kicker m-0">INSTALL</h2></div>
      <div class="term" aria-label="Install command">
        <div><span class="prompt">$</span> npm install -g mitre-mcp <span style="color: var(--text-dim);"># install the binary</span></div>
        <div><span class="prompt">$</span> npx mitre-mcp <span style="color: var(--text-dim);"># or run it directly</span></div>
      </div>
      <p class="text-sm mt-4 max-w-2xl" style="color: var(--text-dim);">
        Requires Node.js 20+ and internet access for the initial ATT&amp;CK data download (cached
        after first run). The core ATT&amp;CK tools need no credentials. Add
        <span class="font-mono">WAZUH_*</span>, <span class="font-mono">THEHIVE_*</span>,
        <span class="font-mono">CORTEX_*</span>, or <span class="font-mono">MISP_*</span> env vars
        to light up the SOC integrations.
      </p>
    </section>

    <!-- ============================ CAPABILITIES ============================ -->
    <section class="mb-12">
      <div class="section-rule mb-5"><h2 class="kicker m-0">TOOLS EXPOSED</h2></div>
      {toolGroups.map((g) => (
        <>
          <p class="cap-group-label">{g.group}</p>
          <div class="cap-list">
            {g.tools.map((t) => (
              <div class="cap"><div class="cap-desc" style="grid-column: 1 / -1;">{t}</div></div>
            ))}
          </div>
        </>
      ))}
    </section>

    <!-- ============================ CLIENT CONFIG ============================ -->
    <section class="mb-12">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CLIENT CONFIG</h2></div>
      <p class="max-w-2xl mb-4" style="color: var(--text-muted);">
        A sample <span class="font-mono">mcpServers</span> entry for an MCP client such as Claude
        Desktop. The server speaks MCP over stdio. SOC integration env vars are optional.
      </p>
      <pre class="term" aria-label="MCP client configuration"><code>{`{
  "mcpServers": {
    "mitre-attack": {
      "command": "mitre-mcp",
      "env": {
        "MITRE_MATRICES": "enterprise"
      }
    }
  }
}`}</code></pre>
    </section>
  </main>
</BaseLayout>
