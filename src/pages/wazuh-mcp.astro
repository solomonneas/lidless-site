---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../lib/tools.ts';
import {
  softwareApplicationLd,
  organizationLd,
  absoluteImage,
  graph,
} from '../lib/seo.ts';

const tool = TOOLS.find((t) => t.slug === 'wazuh-mcp')!;
const { name, oneLiner, lifecycle, category, repo, npm } = tool;

const pageUrl = 'https://lidless.dev/wazuh-mcp';
const title = 'Wazuh MCP server - query your SIEM with AI';
const description =
  'wazuh-mcp is an open-source MCP server for the Wazuh SIEM/XDR. Query agents, alerts, vulnerabilities, rules, and SCA from Claude or any MCP client over stdio.';

const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name,
    siteUrl: pageUrl,
    description,
    image: absoluteImage('https://lidless.dev', '/og-card.png'),
    codeRepository: repo,
    license: 'MIT',
  }),
]);

const badgeClass =
  lifecycle === 'Active'
    ? 'badge badge-active'
    : lifecycle === 'WIP'
      ? 'badge badge-wip'
      : 'badge badge-experimental';

// Capabilities, grouped as the README documents them.
const toolGroups: { group: string; tools: { name: string; desc: string }[] }[] = [
  {
    group: 'Agents & system inventory',
    tools: [
      { name: 'list_agents / get_agent / get_agent_stats', desc: 'Enumerate agents with status filters; pull CPU, memory, and disk stats.' },
      { name: 'get_agent_os / get_agent_packages / get_agent_processes', desc: 'Syscollector OS, installed package, and process inventory.' },
      { name: 'get_agent_ports / get_agent_network / get_agent_hotfixes', desc: 'Open ports, network interfaces, and Windows hotfixes per agent.' },
    ],
  },
  {
    group: 'Alerts & vulnerabilities',
    tools: [
      { name: 'get_alerts / get_alert / search_alerts', desc: 'Retrieve and full-text search alerts by time range, level, agent, and rule (via the Wazuh Indexer).' },
      { name: 'list_vulnerabilities / search_vulnerabilities', desc: 'Query the CVE inventory by CVE, agent, severity, and package.' },
    ],
  },
  {
    group: 'Detection content',
    tools: [
      { name: 'list_rules / get_rule / search_rules', desc: 'Browse detection rules with level/group filters and full compliance mappings.' },
      { name: 'list_decoders', desc: 'List log decoders with optional name filtering.' },
    ],
  },
  {
    group: 'Posture & integrity',
    tools: [
      { name: 'get_sca_policies / get_sca_checks', desc: 'Security Configuration Assessment policies, scores, and per-check remediation.' },
      { name: 'get_fim_files / get_rootcheck', desc: 'File Integrity Monitoring results and rootkit-detection findings.' },
    ],
  },
  {
    group: 'Manager, groups & diagnostics',
    tools: [
      { name: 'get_manager_logs / get_manager_config', desc: 'Manager logs by level/module and active config (secrets redacted by default).' },
      { name: 'list_groups / get_group_agents', desc: 'List agent groups and the agents inside each one.' },
      { name: 'get_wazuh_version / diagnose_wazuh_connection', desc: 'Version info plus a sanitized connection/TLS/auth/indexer-readiness check.' },
    ],
  },
];
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="tool-page px-6 md:px-10 py-12 max-w-4xl mx-auto">
    <!-- breadcrumb / back to hub -->
    <nav class="kicker mb-7" aria-label="Breadcrumb">
      <a href="/" style="color: var(--text-dim); text-decoration: none;">&larr; Lidless</a>
      <span style="color: var(--text-dim);"> / {category} / {name}</span>
    </nav>

    <!-- ============================ HERO ============================ -->
    <header class="mb-10">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="wordmark text-4xl md:text-5xl m-0">{name}</h1>
        <span class={badgeClass}>{lifecycle}</span>
      </div>
      <p class="text-lg mt-4 max-w-2xl" style="color: var(--text-muted);">{oneLiner}</p>
      <div class="tool-cta">
        <a class="btn-primary" href={tool.repo} rel="noopener">GitHub repo &rarr;</a>
        {tool.npm
          ? <a class="btn-ghost" href={`https://www.npmjs.com/package/${tool.npm}`} rel="noopener">npm: {tool.npm} &rarr;</a>
          : <span class="cta-note">self-hosted &middot; run from source</span>}
      </div>
      <div class="flex flex-wrap gap-3 mt-6 items-center">
        {npm && (
          <span class="npm-tag">npm i -g {npm}</span>
        )}
      </div>
    </header>

    <!-- ============================ WHAT IT DOES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT DOES</h2></div>
      <div class="max-w-2xl" style="color: var(--text-muted);">
        <p class="mb-4">
          <code>wazuh-mcp</code> is a Model Context Protocol server for the
          <a href="https://wazuh.com/" rel="noopener" style="color: var(--accent);">Wazuh</a>
          SIEM/XDR platform. Point an MCP-compatible client at it and your Wazuh deployment
          becomes a set of tools the agent can call: enumerate agents, pull security alerts,
          review the CVE backlog, read detection rules and decoders, and run posture checks
          without leaving the assistant.
        </p>
        <p class="mb-4">
          It exposes 28 tools, 3 read-only resources, and 3 guided prompts. Authentication is
          handled with automatic JWT token management against the Wazuh API, and alert and
          vulnerability queries run against the Wazuh Indexer (OpenSearch) when configured.
          Compliance mappings (PCI-DSS, GDPR, HIPAA, NIST 800-53, MITRE ATT&CK) ride along on
          rule lookups.
        </p>
        <p>
          Sensitive fields (IPs, full logs, hashes, command lines, secret config values) are
          minimized by default and only returned on explicit opt-in. SIEM content that
          originates on monitored endpoints is wrapped in untrusted-data markers to blunt
          prompt injection against the calling agent.
        </p>
      </div>
    </section>

    <!-- ============================ INSTALL ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">INSTALL</h2></div>
      <p class="max-w-2xl mb-4" style="color: var(--text-muted);">
        Published to npm. Install globally to get the <code>wazuh-mcp</code> binary, or run it
        on demand with <code>npx</code>. Requires Node.js 20+ and a running Wazuh manager with
        API access.
      </p>
      <div class="term" aria-label="Install wazuh-mcp from npm">
        <div><span class="prompt">$</span> npm i -g wazuh-mcp        <span style="color: var(--text-dim);"># install the server binary</span></div>
        <div><span class="prompt">$</span> npx wazuh-mcp             <span style="color: var(--text-dim);"># or run it without installing</span></div>
      </div>
      <p class="text-sm mt-4 max-w-2xl" style="color: var(--text-dim);">
        Configure with <code>WAZUH_URL</code>, <code>WAZUH_USERNAME</code>, and
        <code>WAZUH_PASSWORD</code>. Set <code>WAZUH_INDEXER_URL</code> (plus indexer
        credentials) to enable alert and vulnerability tools.
      </p>
    </section>

    <!-- ============================ CLIENT CONFIG ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CLIENT CONFIG</h2></div>
      <p class="max-w-2xl mb-4" style="color: var(--text-muted);">
        A sample <code>mcpServers</code> entry (Claude Desktop, or any MCP client that reads the
        same shape). It runs the installed binary over stdio.
      </p>
      <div class="term" aria-label="Sample MCP client configuration for wazuh-mcp">
        <pre style="margin:0;white-space:pre-wrap;">{`{
  "mcpServers": {
    "wazuh": {
      "command": "wazuh-mcp",
      "env": {
        "WAZUH_URL": "https://your-wazuh-manager:55000",
        "WAZUH_USERNAME": "wazuh-wui",
        "WAZUH_PASSWORD": "your-password",
        "WAZUH_INDEXER_URL": "https://your-wazuh-indexer:9200",
        "WAZUH_INDEXER_USERNAME": "admin",
        "WAZUH_INDEXER_PASSWORD": "your-indexer-password"
      }
    }
  }
}`}</pre>
      </div>
      <p class="text-sm mt-4 max-w-2xl" style="color: var(--text-dim);">
        For Claude Code use <code>claude mcp add wazuh ... -- wazuh-mcp</code>. The repo README
        also documents OpenClaw, Codex CLI, and Hermes Agent.
      </p>
    </section>

    <!-- ============================ CAPABILITIES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CAPABILITIES / TOOLS EXPOSED</h2></div>
      <p class="max-w-2xl mb-6" style="color: var(--text-muted);">
        28 MCP tools across agents, alerts, vulnerabilities, detection content, posture, and
        the manager. Grouped below; see the README for the full per-argument reference.
      </p>
      {toolGroups.map((g) => (
        <>
          <p class="cap-group-label">{g.group}</p>
          <div class="cap-list">
            {g.tools.map((t) => (
              <div class="cap">
                <div class="cap-name">{t.name}</div>
                <div class="cap-desc">{t.desc}</div>
              </div>
            ))}
          </div>
        </>
      ))}
      <p class="text-sm mt-6 max-w-2xl" style="color: var(--text-dim);">
        Plus 3 resources (<code>wazuh://agents</code>, <code>wazuh://alerts/recent</code>,
        <code>wazuh://rules/summary</code>) and 3 prompts (investigate-alert,
        agent-health-check, security-overview).
      </p>
    </section>

    <!-- ============================ SPEC STRIP ============================ -->
    <section class="mb-10">
      <div class="spec-strip">
        <div class="spec"><div class="n">28</div><div class="l">MCP tools</div></div>
        <div class="spec"><div class="n">3</div><div class="l">resources</div></div>
        <div class="spec"><div class="n">3</div><div class="l">prompts</div></div>
        <div class="spec"><div class="n">MIT</div><div class="l">license</div></div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .tool-page code {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.88em;
    color: var(--text);
  }
</style>
