---
import { NAV_LINKS, EXTERNAL } from '../lib/site.ts';
---
<nav class="border-b" style="border-color: var(--hairline);">
  <div class="flex items-center gap-6 px-6 md:px-10 py-4 text-sm">
    <a href="/" class="inline-flex items-center gap-2 font-mono font-medium text-base tracking-tight" style="color: var(--white);">
      <svg width="20" height="20" viewBox="0 0 120 120" aria-hidden="true">
        <!-- small blue echo of the hero eye: socket ring + blue iris + pupil -->
        <circle cx="60" cy="60" r="50" fill="none" stroke="var(--accent)" stroke-width="6"/>
        <circle cx="60" cy="60" r="44" fill="var(--bg-panel)"/>
        <circle cx="60" cy="60" r="17" fill="none" stroke="var(--accent)" stroke-width="5"/>
        <circle cx="60" cy="60" r="7" fill="var(--accent)"/>
      </svg>
      <span>LIDLESS<span style="color: var(--accent);">_</span></span>
    </a>
    {NAV_LINKS.map((l) => <a href={l.href} class="hidden sm:inline" style="color: var(--text-muted);">{l.label}</a>)}
    <span class="flex-1"></span>
    <a href={EXTERNAL.github} id="ghStar" data-org="lidless-labs"
      class="gh-star inline-flex items-center rounded-md border overflow-hidden"
      style="border-color: var(--hairline);" aria-label="Lidless on GitHub">
      <span class="inline-flex items-center gap-2 px-3 py-1.5" style="background: var(--bg-panel);">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="var(--accent)" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
        <span>GitHub</span>
      </span>
      <span class="gh-star-count font-mono text-xs px-2.5 py-1.5"
        style="background: var(--bg-panel-2); border-left: 1px solid var(--hairline); color: var(--text-muted); display: none;"
        aria-live="polite"></span>
    </a>
  </div>
  <!-- mobile: the category links get their own row instead of disappearing -->
  <div class="flex sm:hidden gap-5 px-6 pb-3 text-sm overflow-x-auto whitespace-nowrap">
    {NAV_LINKS.map((l) => <a href={l.href} style="color: var(--text-muted);">{l.label}</a>)}
  </div>
</nav>

<style>
  .gh-star { transition: border-color 0.15s ease; }
  .gh-star:hover { border-color: var(--accent); }
</style>

<script>
  // Live "Lidless on GitHub" star count: the total stars across the lidless-labs
  // org, one API call, cached 6h. Lidless has no single flagship repo, so the
  // org total is the meaningful number. Fails soft: no data, the segment stays
  // hidden and the button is a plain GitHub link.
  const el = document.getElementById('ghStar');
  if (el) {
    const org = el.getAttribute('data-org') || '';
    const seg = el.querySelector('.gh-star-count') as HTMLElement | null;
    const fmt = (n: number) =>
      n >= 1e6 ? (n / 1e6).toFixed(1).replace(/\.0$/, '') + 'M'
      : n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k'
      : String(n);
    // Hide the count until there are stars, so a new project does not advertise "0".
    const render = (n: number) => { if (seg && n > 0) { seg.textContent = '★ ' + fmt(n); seg.style.display = 'inline-block'; } };
    const KEY = 'gh-org-stars:' + org;
    const TTL = 6 * 3600 * 1000;
    try {
      const c = JSON.parse(localStorage.getItem(KEY) || 'null');
      if (c && typeof c.n === 'number' && Date.now() - c.t < TTL) render(c.n);
    } catch {}
    fetch('https://api.github.com/orgs/' + org + '/repos?per_page=100&type=public', {
      headers: { Accept: 'application/vnd.github+json' },
    })
      .then((r) => (r.ok ? r.json() : null))
      .then((d) => {
        if (Array.isArray(d)) {
          const total = d.reduce((s: number, r: { stargazers_count?: number }) => s + (r.stargazers_count || 0), 0);
          render(total);
          try { localStorage.setItem(KEY, JSON.stringify({ n: total, t: Date.now() })); } catch {}
        }
      })
      .catch(() => {});
  }
</script>
