---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolStatus from '../components/ToolStatus.astro';
import { TOOLS } from '../lib/tools.ts';
import { PAGES } from '../lib/tool-pages.ts';
import { softwareApplicationLd, organizationLd, absoluteImage, graph } from '../lib/seo.ts';

export function getStaticPaths() {
  return Object.keys(PAGES).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const tool = TOOLS.find((t) => t.slug === slug)!;
const page = PAGES[slug!]!;
const { name, lifecycle, category, repo, npm } = tool;

const pageUrl = `https://lidless.dev/${slug}`;
const title = `${name} - ${page.value.split(/[.:]/)[0].trim().toLowerCase()}`.slice(0, 68);
const description = page.value.replace(/\s+/g, ' ').slice(0, 155);
const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name,
    siteUrl: pageUrl,
    description,
    image: absoluteImage('https://lidless.dev', '/og-card.png'),
    codeRepository: repo,
    license: 'MIT',
  }),
]);

const lifeClass =
  lifecycle === 'Active' ? 'tp-chip active' : lifecycle === 'WIP' ? 'tp-chip wip' : 'tp-chip exp';
const catAnchor: Record<string, string> = {
  'Security / SOC': 'security',
  'Threat Intelligence & OSINT': 'intel',
  Network: 'network',
  Homelab: 'homelab',
};
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="tp px-6 md:px-10 py-10 max-w-4xl mx-auto">
    <nav class="tp-crumb" aria-label="Breadcrumb">
      <a href="/">Lidless</a> / <a href={`/#${catAnchor[category] ?? ''}`}>{category}</a> / <span>{name}</span>
    </nav>

    <!-- HERO -->
    <header class="tp-hero">
      <div>
        <div class="tp-titlerow">
          <h1 class="tp-h1">{name}</h1>
          <span class={lifeClass}>{lifecycle}</span>
        </div>
        <p class="tp-value" set:html={page.value.replace(name, `<b>${name}</b>`)}></p>
        <div class="tp-cta">
          <a class="tp-btn p" href={repo} rel="noopener">GitHub repo &rarr;</a>
          {npm && <a class="tp-btn g" href={`https://www.npmjs.com/package/${npm}`} rel="noopener">npm: {npm} &rarr;</a>}
        </div>
        {page.meta.length > 0 && (
          <div class="tp-meta">
            {page.meta.map((m) => <span class="tp-tag">{m}</span>)}
          </div>
        )}
      </div>
      <aside class="tp-aside"><ToolStatus slug={slug} /></aside>
    </header>

    <!-- PROOF -->
    {page.proof.type === 'session' && (
      <section class="tp-sec">
        <div class="tp-srule"><h2>See it work</h2><p>one question, the tools it calls, the answer</p></div>
        <div class="tp-session">
          <div class="tp-sbar"><span class="tp-st">{page.proof.label}</span></div>
          <div class="tp-sbody">
            {page.proof.turns.map((t) => (
              <>
                {t.ask && <div class="tp-ask">{t.ask}</div>}
                {t.call && <div class="tp-call">{t.call}</div>}
                {t.ret && <div class="tp-ret">{t.ret}</div>}
                {t.say && <div class="tp-say" set:html={t.say.replace(/^([^.]+\.)/, '<b>$1</b>')}></div>}
              </>
            ))}
          </div>
        </div>
        <p class="tp-caption">{page.proof.caption}</p>
      </section>
    )}
    {page.proof.type === 'screenshot' && (
      <section class="tp-sec">
        <div class="tp-srule"><h2>See it work</h2></div>
        <figure class="tp-shot">
          <img src={page.proof.src} alt={page.proof.alt} loading="lazy" />
          <figcaption>{page.proof.caption}</figcaption>
        </figure>
      </section>
    )}

    <!-- WHAT IT DOES -->
    <section class="tp-sec">
      <div class="tp-srule"><h2>What it does</h2></div>
      <p class="tp-body">{page.what}</p>
    </section>

    <!-- CAPABILITIES -->
    {page.capabilities && (
      <section class="tp-sec">
        <div class="tp-srule"><h2>Capabilities</h2><p>{page.capabilities.title}</p></div>
        <div class="tp-capgrid">
          {page.capabilities.groups.map((g) => (
            <div class="tp-capgroup">
              <div class="tp-caphead"><span class="tp-capname">{g.name}</span>{g.count && <span class="tp-capct">{g.count}</span>}</div>
              <div class="tp-capdesc">{g.desc}</div>
            </div>
          ))}
          {page.capabilities.refHref && (
            <a class="tp-capgroup tp-capref" href={page.capabilities.refHref} rel="noopener">Full reference on GitHub &rarr;</a>
          )}
        </div>
      </section>
    )}

    <!-- SETUP -->
    {page.setup && (
      <section class="tp-sec">
        <div class="tp-srule"><h2>Set it up</h2></div>
        {page.setup.install && <div class="tp-term">{page.setup.install}</div>}
        {page.setup.env && <p class="tp-body dim">{page.setup.env}</p>}
        {page.setup.config && (
          <details class="tp-details">
            <summary>{page.setup.configLabel ?? 'Client config'}</summary>
            <div class="tp-inner"><pre>{page.setup.config}</pre></div>
          </details>
        )}
      </section>
    )}

    <!-- SAFETY -->
    {page.safety && (
      <section class="tp-sec">
        <div class="tp-safety"><span class="tp-ico">[ shield ]</span><p>{page.safety}</p></div>
      </section>
    )}

    <!-- SPECS -->
    {page.specs.length > 0 && (
      <div class="tp-specs">
        {page.specs.map((s) => <div class="tp-spec"><div class="tp-n">{s.n}</div><div class="tp-sl">{s.l}</div></div>)}
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .tp { color: var(--text); }
  .tp-crumb { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12px; color: var(--text-dim); letter-spacing: 0.04em; margin-bottom: 22px; }
  .tp-crumb a { color: var(--text-dim); text-decoration: none; }
  .tp-crumb a:hover { color: var(--accent); }
  .tp-crumb span { color: var(--text-muted); }

  .tp-hero { display: grid; grid-template-columns: 1.6fr 1fr; gap: 26px; align-items: start; border-bottom: 1px solid var(--hairline); padding-bottom: 26px; }
  .tp-titlerow { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .tp-h1 { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: clamp(26px, 4vw, 36px); margin: 0; color: var(--white); letter-spacing: 0.01em; }
  .tp-chip { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 9px; border-radius: 999px; display: inline-flex; align-items: center; gap: 6px; }
  .tp-chip::before { content: ""; width: 7px; height: 7px; border-radius: 50%; }
  .tp-chip.active { color: #4ade80; background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.3); }
  .tp-chip.active::before { background: #4ade80; }
  .tp-chip.wip { color: var(--warn); background: rgba(216,166,87,0.08); border: 1px solid rgba(216,166,87,0.3); }
  .tp-chip.wip::before { background: var(--warn); }
  .tp-chip.exp { color: var(--text-muted); background: var(--bg-panel-2); border: 1px solid var(--hairline-strong); }
  .tp-chip.exp::before { background: var(--text-muted); }
  .tp-value { font-size: 19px; color: var(--white); font-weight: 500; margin: 14px 0 0; max-width: 52ch; line-height: 1.5; }
  .tp-value b { color: var(--accent); font-weight: 600; }
  .tp-cta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }
  .tp-btn { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12.5px; padding: 9px 15px; border-radius: 8px; text-decoration: none; }
  .tp-btn.p { background: var(--accent); color: #061320; font-weight: 600; }
  .tp-btn.g { border: 1px solid var(--hairline-strong); color: var(--text); }
  .tp-btn.g:hover { border-color: var(--accent-dim); }
  .tp-meta { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 16px; }
  .tp-tag { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; color: var(--text-muted); background: var(--bg-panel-2); border: 1px solid var(--hairline-strong); border-radius: 6px; padding: 4px 9px; }
  .tp-aside { min-width: 0; }

  .tp-sec { margin-top: 36px; }
  .tp-srule { display: flex; align-items: baseline; gap: 13px; border-bottom: 1px solid var(--hairline-strong); padding-bottom: 11px; margin-bottom: 18px; }
  .tp-srule h2 { font-family: "Outfit", ui-sans-serif, system-ui, sans-serif; font-size: 21px; font-weight: 700; letter-spacing: -0.01em; color: var(--white); margin: 0; display: inline-flex; align-items: center; gap: 11px; }
  .tp-srule h2::before { content: ""; width: 4px; height: 17px; border-radius: 2px; background: var(--accent); }
  .tp-srule p { margin: 0; color: var(--text-muted); font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12px; letter-spacing: 0.02em; }
  .tp-body { color: var(--text); max-width: 70ch; font-size: 16px; line-height: 1.65; }
  .tp-body.dim { color: var(--text-muted); font-size: 14.5px; margin-top: 12px; }

  .tp-session { background: var(--bg-panel); border: 1px solid var(--hairline-strong); border-radius: 12px; overflow: hidden; }
  .tp-sbar { padding: 11px 18px; border-bottom: 1px solid var(--hairline); }
  .tp-st { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); }
  .tp-sbody { padding: 18px; }
  .tp-ask, .tp-say { font-family: "Instrument Sans", ui-sans-serif, system-ui, sans-serif; font-size: 16px; line-height: 1.6; }
  .tp-ask { color: var(--white); }
  .tp-ask::before, .tp-say::before { display: inline-block; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase; padding: 2px 7px; border-radius: 5px; margin-right: 10px; vertical-align: 1px; }
  .tp-ask::before { content: "You"; color: var(--accent); background: rgba(56,189,248,0.10); }
  .tp-say::before { content: "Agent"; color: #4ade80; background: rgba(74,222,128,0.10); }
  .tp-call { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 13.5px; color: var(--accent); background: #070a10; border: 1px solid var(--hairline); border-radius: 7px; padding: 8px 11px; margin: 12px 0 4px; overflow-x: auto; }
  .tp-call::before { content: "\2192  "; color: var(--text-dim); }
  .tp-ret { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 13.5px; color: var(--text-muted); white-space: pre-wrap; border-left: 2px solid var(--accent-dim); padding: 3px 0 3px 13px; margin: 0 0 10px; line-height: 1.6; overflow-x: auto; }
  .tp-say { color: var(--text); margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--hairline); }
  .tp-say b { color: var(--white); font-weight: 600; }
  .tp-caption { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; color: var(--text-dim); margin-top: 9px; text-align: center; }

  .tp-shot { margin: 0; border: 1px solid var(--hairline-strong); border-radius: 11px; overflow: hidden; }
  .tp-shot img { display: block; width: 100%; height: auto; }
  .tp-shot figcaption { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; color: var(--text-dim); padding: 10px 14px; border-top: 1px solid var(--hairline); }

  .tp-capgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .tp-capgroup { border: 1px solid var(--hairline); border-radius: 9px; padding: 13px 15px; background: var(--bg-panel); }
  .tp-caphead { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; gap: 8px; }
  .tp-capname { font-family: "Outfit", ui-sans-serif, system-ui, sans-serif; font-size: 15px; font-weight: 600; color: var(--white); }
  .tp-capct { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; color: var(--accent); white-space: nowrap; }
  .tp-capdesc { color: var(--text-muted); font-size: 13.5px; }
  .tp-capref { display: flex; align-items: center; justify-content: center; border-style: dashed; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12.5px; color: var(--accent); text-decoration: none; }

  .tp-term { background: #070a10; border: 1px solid var(--hairline-strong); border-radius: 9px; padding: 13px 15px; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12.5px; color: var(--text); white-space: pre-wrap; }
  .tp-details { margin-top: 12px; border: 1px solid var(--hairline); border-radius: 9px; background: var(--bg-panel); }
  .tp-details summary { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12px; color: var(--text-muted); padding: 11px 14px; cursor: pointer; list-style: none; }
  .tp-details summary::-webkit-details-marker { display: none; }
  .tp-details summary::before { content: "\25B8  "; color: var(--accent); }
  .tp-details[open] summary::before { content: "\25BE  "; }
  .tp-inner { padding: 0 14px 14px; }
  .tp-inner pre { margin: 0; background: #070a10; border: 1px solid var(--hairline); border-radius: 8px; padding: 12px; overflow-x: auto; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12px; color: var(--text); line-height: 1.55; }

  .tp-safety { display: flex; gap: 13px; border: 1px solid rgba(56,189,248,0.24); background: rgba(56,189,248,0.05); border-radius: 10px; padding: 14px 16px; }
  .tp-ico { font-family: "JetBrains Mono", ui-monospace, monospace; color: var(--accent); font-size: 13px; flex-shrink: 0; }
  .tp-safety p { margin: 0; color: var(--text); font-size: 13.5px; }

  .tp-specs { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-top: 34px; border-top: 1px solid var(--hairline); padding-top: 22px; }
  .tp-spec { text-align: center; }
  .tp-n { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 22px; color: var(--white); font-variant-numeric: tabular-nums; }
  .tp-sl { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim); margin-top: 3px; }

  @media (max-width: 760px) {
    .tp-hero { grid-template-columns: 1fr; }
    .tp-aside { order: -1; }
    .tp-capgrid { grid-template-columns: 1fr; }
    .tp-specs { grid-template-columns: repeat(2, 1fr); gap: 18px; }
  }
</style>
