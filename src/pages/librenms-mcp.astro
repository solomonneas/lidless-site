---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../lib/tools.ts';
import {
  softwareApplicationLd,
  organizationLd,
  absoluteImage,
  graph,
} from '../lib/seo.ts';

const tool = TOOLS.find((t) => t.slug === 'librenms-mcp')!;

const title = 'librenms-mcp - read your LibreNMS NMS from an AI client';
const description =
  'librenms-mcp is a work-in-progress MCP server for LibreNMS: 10 read tools for devices, ports, alerts, and events, plus 3 confirm-gated safe writes. API-token auth, write gating built in.';

const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name: tool.name,
    siteUrl: 'https://lidless.dev/librenms-mcp',
    description,
    image: absoluteImage('https://lidless.dev', '/og-card.png'),
    codeRepository: tool.repo,
    license: 'https://opensource.org/licenses/MIT',
  }),
]);

const badgeClass =
  tool.lifecycle === 'Active'
    ? 'badge badge-active'
    : tool.lifecycle === 'WIP'
      ? 'badge badge-wip'
      : 'badge badge-experimental';

const readTools = [
  { name: 'librenms_status', desc: 'LibreNMS instance status check.' },
  { name: 'librenms_list_devices', desc: 'List monitored devices.' },
  { name: 'librenms_get_device', desc: 'Fetch a single device by id.' },
  { name: 'librenms_list_ports', desc: 'List ports across devices.' },
  { name: 'librenms_get_port', desc: 'Fetch a single port detail.' },
  { name: 'librenms_port_health', desc: 'Port health and utilization view.' },
  { name: 'librenms_list_alerts', desc: 'List current alerts.' },
  { name: 'librenms_get_alert', desc: 'Fetch a single alert by id.' },
  { name: 'librenms_alert_history', desc: 'Historical alert records.' },
  { name: 'librenms_event_log', desc: 'Read the device event log.' },
];

const writeTools = [
  { name: 'librenms_ack_alert', desc: 'Acknowledge an alert.' },
  { name: 'librenms_unmute_alert', desc: 'Unmute a previously muted alert.' },
  { name: 'librenms_set_maintenance', desc: 'Put a device into maintenance.' },
];

const clientConfig = `{
  "mcpServers": {
    "librenms": {
      "command": "npx",
      "args": ["-y", "@solomonneas/librenms-mcp"],
      "env": {
        "LIBRENMS_URL": "https://librenms.example.local",
        "LIBRENMS_TOKEN": "<your-api-token>",
        "LIBRENMS_TLS_INSECURE": "false"
      }
    }
  }
}`;
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="px-6 md:px-10 py-12 max-w-4xl mx-auto">
    <!-- breadcrumb / back to hub -->
    <nav class="kicker mb-6" aria-label="Breadcrumb">
      <a href="/" style="text-decoration: none;">&larr; Lidless</a>
      <span style="color: var(--text-dim);"> / Network / {tool.name}</span>
    </nav>

    <!-- ============================ HERO ============================ -->
    <header class="mb-8">
      <div class="flex items-center gap-3 flex-wrap mb-3">
        <h1 class="wordmark text-4xl md:text-5xl uppercase m-0">{tool.name}</h1>
        <span class={badgeClass}>{tool.lifecycle}</span>
      </div>
      <p class="text-lg" style="color: var(--text-muted); max-width: 42rem;">
        {tool.oneLiner}
      </p>
      <div class="tool-cta">
        <a class="btn-primary" href={tool.repo} rel="noopener">GitHub repo &rarr;</a>
        {tool.npm
          ? <a class="btn-ghost" href={`https://www.npmjs.com/package/${tool.npm}`} rel="noopener">npm: {tool.npm} &rarr;</a>
          : <span class="cta-note">self-hosted &middot; run from source</span>}
      </div>
    </header>

    <!-- ============================ MATURITY NOTE ============================ -->
    <div class="mb-10 rounded-md p-4" style="border: 1px solid color-mix(in srgb, var(--warn) 35%, transparent); background: color-mix(in srgb, var(--warn) 8%, transparent);">
      <p class="m-0" style="color: var(--text-muted); font-size: 0.9rem;">
        <span class="font-mono" style="color: var(--warn);">WIP &middot;</span>
        This is a work-in-progress release. v1 ships read tools (tier 1) and confirm-gated safe
        writes (tier 2) only. Destructive operations (tier 3) such as device deletion, alert-rule
        removal, and bulk port resets are intentionally deferred until the write-gate pattern has
        more field time.
      </p>
    </div>

    <!-- ============================ WHAT IT DOES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT DOES</h2></div>
      <div style="color: var(--text-muted); max-width: 46rem;">
        <p class="mb-4">
          librenms-mcp is a Model Context Protocol server for
          <a href="https://www.librenms.org/" rel="noopener" style="color: var(--accent);">LibreNMS</a>,
          the open-source network monitoring system. It authenticates with a LibreNMS API token and
          lets an AI client read your monitoring surface: devices, ports, port health, current
          alerts, alert history, and the event log.
        </p>
        <p class="mb-4">
          Writes are gated in three tiers. Reads are open. Safe writes (acknowledge an alert, unmute
          it, enter device maintenance) require an explicit <code class="font-mono">confirm: true</code>
          argument, so a hallucinated tool call throws <code class="font-mono">WriteGateError</code>
          before any HTTP traffic leaves the host. Destructive operations are not implemented yet.
        </p>
        <p>
          Every tool call is validated against its published TypeBox input schema before it runs;
          ids, limits, and enum filters are bounds-checked and interpolated values are URL-encoded.
          The API token is registered with a redactor on startup and masked from all log and error
          output.
        </p>
      </div>
    </section>

    <!-- ============================ INSTALL ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">INSTALL</h2></div>
      <p class="mb-4" style="color: var(--text-muted);">
        Published to npm as <code class="font-mono" style="color: var(--accent);">@solomonneas/librenms-mcp</code>.
        Install the global binary, or run it on demand with <span class="font-mono">npx</span>.
      </p>
      <div class="term" aria-label="Install command">
        <div><span class="prompt">$</span> npm install -g @solomonneas/librenms-mcp</div>
        <div><span class="prompt">$</span> npx -y @solomonneas/librenms-mcp <span style="color: var(--text-dim);"># run on demand</span></div>
      </div>
    </section>

    <!-- ============================ CAPABILITIES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CAPABILITIES / TOOLS EXPOSED</h2></div>

      <p class="cap-group-label">Reads (10) &middot; open</p>
      <div class="cap-list">
        {readTools.map((t) => (
          <div class="cap">
            <div class="cap-name">{t.name}</div>
            <div class="cap-desc">{t.desc}</div>
          </div>
        ))}
      </div>

      <p class="cap-group-label">Safe writes (3) &middot; require confirm: true</p>
      <div class="cap-list">
        {writeTools.map((t) => (
          <div class="cap">
            <div class="cap-name" style="color: var(--warn);">{t.name}</div>
            <div class="cap-desc">{t.desc}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- ============================ CLIENT CONFIG ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CLIENT CONFIG</h2></div>
      <p class="mb-4" style="color: var(--text-muted);">
        Stdio transport via <span class="font-mono">npx</span>. Both
        <code class="font-mono">LIBRENMS_URL</code> and
        <code class="font-mono">LIBRENMS_TOKEN</code> are required. Example
        <span class="font-mono">mcpServers</span> entry (Claude Desktop / Claude Code):
      </p>
      <pre class="term" aria-label="MCP client configuration"><code>{clientConfig}</code></pre>
      <p class="text-sm mt-3" style="color: var(--text-dim);">
        Start with a <strong>read-only</strong> LibreNMS API token role and confirm the read tools
        work end-to-end before grading up. Set
        <code class="font-mono">LIBRENMS_TLS_INSECURE=true</code> only for homelab self-signed certs.
      </p>
    </section>
  </main>
</BaseLayout>
