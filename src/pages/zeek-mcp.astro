---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolStatus from '../components/ToolStatus.astro';
import { TOOLS } from '../lib/tools.ts';
import {
  softwareApplicationLd,
  organizationLd,
  absoluteImage,
  graph,
} from '../lib/seo.ts';

const tool = TOOLS.find((t) => t.slug === 'zeek-mcp')!;

const title = 'zeek-mcp - query Zeek + Suricata logs from your AI client';
const description =
  'zeek-mcp is an MCP server for Zeek and Suricata: 25 tools to query connection, DNS, HTTP, SSL, and IDS logs, detect C2 beaconing, and run guided network investigations.';

const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name: tool.name,
    siteUrl: 'https://lidless.dev/zeek-mcp',
    description,
    image: absoluteImage('https://lidless.dev', '/og-card.png'),
    codeRepository: tool.repo,
    license: 'https://opensource.org/licenses/MIT',
  }),
]);

const badgeClass =
  tool.lifecycle === 'Active'
    ? 'badge badge-active'
    : tool.lifecycle === 'WIP'
      ? 'badge badge-wip'
      : 'badge badge-experimental';

// README "Tools" section, grouped as the README groups them.
const toolGroups: { group: string; tools: { name: string; desc: string }[] }[] = [
  {
    group: 'Connection analysis',
    tools: [
      { name: 'zeek_query_connections', desc: 'Search connection logs (CIDR, protocol, duration, bytes).' },
      { name: 'zeek_connection_summary', desc: 'Top talkers, services, bytes, and connection counts.' },
      { name: 'zeek_long_connections', desc: 'Find long-lived connections (potential C2 beacons, tunnels).' },
    ],
  },
  {
    group: 'DNS analysis',
    tools: [
      { name: 'zeek_query_dns', desc: 'Search DNS queries with domain wildcards and response-code filters.' },
      { name: 'zeek_dns_summary', desc: 'Top domains, NXDOMAIN counts (DGA), query-type distribution.' },
      { name: 'zeek_dns_tunneling_check', desc: 'Detect DNS tunneling via entropy and encoding analysis.' },
    ],
  },
  {
    group: 'HTTP analysis',
    tools: [
      { name: 'zeek_query_http', desc: 'Search HTTP by host, URI, method, user agent, status code.' },
      { name: 'zeek_suspicious_http', desc: 'POSTs to IPs, unusual agents, large bodies, base64 in URLs.' },
    ],
  },
  {
    group: 'SSL/TLS analysis',
    tools: [
      { name: 'zeek_query_ssl', desc: 'Search SSL/TLS by SNI, version, validation status, cert fields.' },
      { name: 'zeek_expired_certs', desc: 'Find expired, self-signed, or invalid certificates.' },
    ],
  },
  {
    group: 'File analysis',
    tools: [
      { name: 'zeek_query_files', desc: 'Search file extractions by MIME type, hash, filename, size.' },
      { name: 'zeek_executable_downloads', desc: 'Find executable transfers (PE, ELF, scripts) on the wire.' },
    ],
  },
  {
    group: 'Notices, SSH & DHCP',
    tools: [
      { name: 'zeek_query_notices', desc: 'Search Zeek security notices (port scans, invalid certs).' },
      { name: 'zeek_query_ssh', desc: 'Search SSH connections by auth status, direction, client/server.' },
      { name: 'zeek_ssh_bruteforce', desc: 'Detect SSH brute-force attempts over a failure threshold.' },
      { name: 'zeek_query_dhcp', desc: 'Search DHCP logs for lease assignments and device discovery.' },
      { name: 'zeek_dhcp_asset_map', desc: 'Build a MAC-to-IP/hostname asset map for inventory.' },
    ],
  },
  {
    group: 'Cross-log investigation & analytics',
    tools: [
      { name: 'zeek_investigate_host', desc: 'Full host investigation across every log type.' },
      { name: 'zeek_investigate_uid', desc: 'Follow one connection UID across all log types.' },
      { name: 'zeek_software_inventory', desc: 'List detected software and versions on the network.' },
      { name: 'zeek_detect_beaconing', desc: 'Detect C2 beaconing via interval regularity and jitter.' },
      { name: 'zeek_detect_anomalies', desc: 'Statistical anomaly detection: scans, exfil, unusual ports.' },
    ],
  },
  {
    group: 'Suricata IDS & sensor',
    tools: [
      { name: 'suricata_query_alerts', desc: 'Search Suricata alerts by signature, severity, IP, protocol, time.' },
      { name: 'suricata_alert_summary', desc: 'Top signatures, categories, IPs, severity distribution.' },
      { name: 'suricata_correlate_zeek', desc: 'Cross-reference Suricata alerts with Zeek logs for context.' },
      { name: 'suricata_eve_stats', desc: 'Engine stats: packets, flows, detection performance.' },
      { name: 'nids_sensor_status', desc: 'Live sensor status: log inventory, sizes, freshness, health.' },
    ],
  },
];

const clientConfig = `{
  "mcpServers": {
    "zeek": {
      "command": "zeek-mcp",
      "env": {
        "ZEEK_LOG_DIR": "/opt/nids/zeek/logs",
        "ZEEK_LOG_FORMAT": "tsv",
        "SURICATA_EVE_LOG": "/opt/nids/suricata/logs/eve.json"
      }
    }
  }
}`;
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="px-6 md:px-10 py-12 max-w-4xl mx-auto">
    <!-- breadcrumb / back to hub -->
    <nav class="kicker mb-6" aria-label="Breadcrumb">
      <a href="/" style="text-decoration: none;">&larr; Lidless</a>
      <span style="color: var(--text-dim);"> / Security / SOC / {tool.name}</span>
    </nav>

    <!-- ============================ HERO ============================ -->
    <header class="mb-10">
      <div class="flex items-center gap-3 flex-wrap mb-3">
        <h1 class="wordmark text-4xl md:text-5xl uppercase m-0">{tool.name}</h1>
        <span class={badgeClass}>{tool.lifecycle}</span>
      </div>
      <p class="text-lg" style="color: var(--text-muted); max-width: 42rem;">
        {tool.oneLiner}
      </p>
      <div class="tool-cta">
        <a class="btn-primary" href={tool.repo} rel="noopener">GitHub repo &rarr;</a>
        {tool.npm
          ? <a class="btn-ghost" href={`https://www.npmjs.com/package/${tool.npm}`} rel="noopener">npm: {tool.npm} &rarr;</a>
          : <span class="cta-note">self-hosted &middot; run from source</span>}
      </div>
    </header>
    <ToolStatus slug="zeek-mcp" />

    <!-- ============================ WHAT IT DOES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT DOES</h2></div>
      <div style="color: var(--text-muted); max-width: 46rem;">
        <p class="mb-4">
          zeek-mcp is a Model Context Protocol server for <a href="https://zeek.org/" rel="noopener"
          style="color: var(--accent);">Zeek</a> and <a href="https://suricata.io/" rel="noopener"
          style="color: var(--accent);">Suricata</a>. It parses your network-security-monitoring
          logs and exposes them as tools an AI client can call directly: connection logs, DNS
          activity, HTTP requests, SSL certificates, file extractions, security notices, and
          Suricata IDS alerts.
        </p>
        <p class="mb-4">
          Beyond raw queries, it ships analytics: statistical C2 beaconing detection with jitter
          scoring, port-scan and data-exfiltration anomaly detection, and DNS-tunneling checks via
          Shannon entropy. Suricata alerts cross-correlate back to the matching Zeek connection for
          full context.
        </p>
        <p>
          It reads both Zeek's native TSV and JSON, handles gzip-archived and date-rotated logs,
          and matches IPv4/IPv6 CIDR ranges and domain wildcards. 25 tools, 2 resources, and 4
          guided-investigation prompts in total.
        </p>
      </div>
    </section>

    <!-- ============================ INSTALL ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">INSTALL</h2></div>
      <p class="mb-4" style="color: var(--text-muted);">
        Published to npm as <code class="font-mono" style="color: var(--accent);">zeek-mcp</code>.
        Install the global binary, or run it on demand with <span class="font-mono">npx</span>.
        Requires Node.js 20+ and a Zeek sensor producing logs.
      </p>
      <div class="term" aria-label="Install command">
        <div><span class="prompt">$</span> npm i -g zeek-mcp</div>
        <div><span class="prompt">$</span> npx zeek-mcp <span style="color: var(--text-dim);"># run on demand</span></div>
      </div>
    </section>

    <!-- ============================ CAPABILITIES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CAPABILITIES / TOOLS EXPOSED</h2></div>
      {toolGroups.map((g) => (
        <>
          <p class="cap-group-label">{g.group}</p>
          <div class="cap-list">
            {g.tools.map((t) => (
              <div class="cap">
                <div class="cap-name">{t.name}</div>
                <div class="cap-desc">{t.desc}</div>
              </div>
            ))}
          </div>
        </>
      ))}
      <p class="text-sm mt-6" style="color: var(--text-dim);">
        Plus 2 resources (<code class="font-mono">zeek://log-types</code>,
        <code class="font-mono">zeek://stats</code>) and 4 prompts
        (<code class="font-mono">triage-alert</code>, <code class="font-mono">investigate-host</code>,
        <code class="font-mono">hunt-for-c2</code>, <code class="font-mono">network-baseline</code>).
        Full reference in the <a href={tool.repo} rel="noopener" style="color: var(--accent);">README</a>.
      </p>
    </section>

    <!-- ============================ CLIENT CONFIG ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CLIENT CONFIG</h2></div>
      <p class="mb-4" style="color: var(--text-muted);">
        Stdio transport. Point any MCP host at the <span class="font-mono">zeek-mcp</span> binary and
        set the log paths in <span class="font-mono">env</span>. Example
        <span class="font-mono">mcpServers</span> entry (Claude Desktop / Claude Code):
      </p>
      <pre class="term" aria-label="MCP client configuration"><code>{clientConfig}</code></pre>
      <p class="text-sm mt-3" style="color: var(--text-dim);">
        Config keys: <code class="font-mono">ZEEK_LOG_DIR</code>,
        <code class="font-mono">ZEEK_LOG_FORMAT</code> (<code class="font-mono">json</code> or
        <code class="font-mono">tsv</code>), <code class="font-mono">ZEEK_LOG_ARCHIVE</code>,
        <code class="font-mono">SURICATA_EVE_LOG</code>, and optional MISP / TheHive / PCAP vars.
      </p>
    </section>
  </main>
</BaseLayout>
