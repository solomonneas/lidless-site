---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../lib/tools.ts';
import {
  softwareApplicationLd,
  organizationLd,
  absoluteImage,
  graph,
} from '../lib/seo.ts';

const tool = TOOLS.find((t) => t.slug === 'misp-mcp')!;
const { name, oneLiner, lifecycle, category, repo, npm } = tool;

const pageUrl = 'https://lidless.dev/misp-mcp';
const title = 'MISP MCP server - threat intel from an AI client';
const description =
  'misp-mcp is an open-source MCP server for MISP threat intelligence. Run IOC lookups, manage events, find correlations, and export IOCs from any MCP client.';

const jsonLd = graph([
  organizationLd(),
  softwareApplicationLd({
    name,
    siteUrl: pageUrl,
    description,
    image: absoluteImage('https://lidless.dev', '/og-card.png'),
    codeRepository: repo,
    license: 'MIT',
  }),
]);

const badgeClass =
  lifecycle === 'Active'
    ? 'badge badge-active'
    : lifecycle === 'WIP'
      ? 'badge badge-wip'
      : 'badge badge-experimental';

// Capabilities, grouped as the README documents them (36 tools).
const toolGroups: { group: string; tools: { name: string; desc: string }[] }[] = [
  {
    group: 'Events',
    tools: [
      { name: 'misp_search_events / misp_get_event', desc: 'Search events by IOC, type, tag, date, or org; pull full event detail with attributes and galaxies.' },
      { name: 'misp_create_event / misp_update_event', desc: 'Create and update events with threat level, distribution, and analysis status.' },
      { name: 'misp_publish_event / misp_tag_event', desc: 'Publish to sharing partners and add/remove TLP, ATT&CK, or custom tags (guarded).' },
    ],
  },
  {
    group: 'Attributes & correlation',
    tools: [
      { name: 'misp_search_attributes / misp_add_attribute / misp_add_attributes_bulk', desc: 'Search IOCs across events; add one or many indicators in a single call.' },
      { name: 'misp_correlate / misp_get_related_events', desc: 'Find everything matching a value and discover events linked through shared IOCs.' },
      { name: 'misp_delete_attribute', desc: 'Soft or hard delete an attribute (confirmation-gated).' },
    ],
  },
  {
    group: 'Exports & sightings',
    tools: [
      { name: 'misp_export_iocs', desc: 'Export IOCs as CSV, STIX, Suricata, Snort, text, or RPZ.' },
      { name: 'misp_export_hashes', desc: 'Export MD5/SHA1/SHA256 hashes for HIDS integration.' },
      { name: 'misp_add_sighting / misp_check_warninglists', desc: 'Report sightings/false positives; check values against benign lists.' },
    ],
  },
  {
    group: 'Tags, objects & galaxies',
    tools: [
      { name: 'misp_list_tags / misp_search_by_tag', desc: 'List tags with usage stats and find events/attributes by tag.' },
      { name: 'misp_list_object_templates / misp_add_object / misp_delete_object', desc: 'Browse templates and add or remove structured (grouped) objects.' },
      { name: 'misp_search_galaxy_clusters / misp_attach_galaxy_cluster', desc: 'Find MITRE ATT&CK techniques and threat actors, then attach them to events.' },
    ],
  },
  {
    group: 'Feeds, orgs & server',
    tools: [
      { name: 'misp_list_feeds / misp_toggle_feed / misp_fetch_feed / misp_cache_feed', desc: 'Manage threat-intel feeds: list, enable, fetch, and cache for correlation.' },
      { name: 'misp_list_organisations / misp_list_sharing_groups', desc: 'List sharing partners and sharing groups for controlled distribution.' },
      { name: 'misp_server_status / misp_delete_event', desc: 'Version and diagnostics; delete an event (confirmation-gated).' },
    ],
  },
];
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main class="tool-page px-6 md:px-10 py-12 max-w-4xl mx-auto">
    <!-- breadcrumb / back to hub -->
    <nav class="kicker mb-7" aria-label="Breadcrumb">
      <a href="/" style="color: var(--text-dim); text-decoration: none;">&larr; Lidless</a>
      <span style="color: var(--text-dim);"> / {category} / {name}</span>
    </nav>

    <!-- ============================ HERO ============================ -->
    <header class="mb-10">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="wordmark text-4xl md:text-5xl m-0">{name}</h1>
        <span class={badgeClass}>{lifecycle}</span>
      </div>
      <p class="text-lg mt-4 max-w-2xl" style="color: var(--text-muted);">{oneLiner}</p>
      <div class="tool-cta">
        <a class="btn-primary" href={tool.repo} rel="noopener">GitHub repo &rarr;</a>
        {tool.npm
          ? <a class="btn-ghost" href={`https://www.npmjs.com/package/${tool.npm}`} rel="noopener">npm: {tool.npm} &rarr;</a>
          : <span class="cta-note">self-hosted &middot; run from source</span>}
      </div>
      <div class="flex flex-wrap gap-3 mt-6 items-center">
        {npm && (
          <span class="npm-tag">npm i -g {npm}</span>
        )}
      </div>
    </header>

    <!-- ============================ WHAT IT DOES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">WHAT IT DOES</h2></div>
      <div class="max-w-2xl" style="color: var(--text-muted);">
        <p class="mb-4">
          <code>misp-mcp</code> is a Model Context Protocol server for
          <a href="https://www.misp-project.org/" rel="noopener" style="color: var(--accent);">MISP</a>,
          the open-source threat-intelligence sharing platform. It lets an LLM run IOC lookups,
          create and manage events, discover cross-event correlations, and export indicators
          directly from your MISP instance.
        </p>
        <p class="mb-4">
          It exposes 36 tools, 3 resources, and 3 guided prompts spanning events, attributes,
          correlations, tags, exports, sightings, warninglists, objects, galaxies, feeds,
          organisations, and server management. MITRE ATT&CK is wired in through galaxy-cluster
          search and attachment, and a correlation engine surfaces relationships through shared
          indicators.
        </p>
        <p>
          State-changing and destructive tools (delete, publish, tag-removal) are guarded: they
          refuse to run without an explicit <code>confirm: true</code>, and permanent hard
          deletes require a second <code>confirmHard: true</code>. SSL verification is flexible
          for the self-signed certs common in MISP deployments.
        </p>
      </div>
    </section>

    <!-- ============================ INSTALL ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">INSTALL</h2></div>
      <p class="max-w-2xl mb-4" style="color: var(--text-muted);">
        Published to npm. Install globally to get the <code>misp-mcp</code> binary, or run it
        on demand with <code>npx</code>. Requires Node.js 20+ and a MISP instance with API
        access plus an API key (Administration &gt; List Auth Keys).
      </p>
      <div class="term" aria-label="Install misp-mcp from npm">
        <div><span class="prompt">$</span> npm i -g misp-mcp         <span style="color: var(--text-dim);"># install the server binary</span></div>
        <div><span class="prompt">$</span> npx misp-mcp              <span style="color: var(--text-dim);"># or run it without installing</span></div>
      </div>
      <p class="text-sm mt-4 max-w-2xl" style="color: var(--text-dim);">
        Configure with <code>MISP_URL</code> and <code>MISP_API_KEY</code>. Set
        <code>MISP_VERIFY_SSL=false</code> for self-signed certs.
      </p>
    </section>

    <!-- ============================ CLIENT CONFIG ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CLIENT CONFIG</h2></div>
      <p class="max-w-2xl mb-4" style="color: var(--text-muted);">
        A sample <code>mcpServers</code> entry (Claude Desktop, or any MCP client that reads the
        same shape). It runs the installed binary over stdio.
      </p>
      <div class="term" aria-label="Sample MCP client configuration for misp-mcp">
        <pre style="margin:0;white-space:pre-wrap;">{`{
  "mcpServers": {
    "misp": {
      "command": "misp-mcp",
      "env": {
        "MISP_URL": "https://misp.example.com",
        "MISP_API_KEY": "your-api-key-here",
        "MISP_VERIFY_SSL": "false"
      }
    }
  }
}`}</pre>
      </div>
      <p class="text-sm mt-4 max-w-2xl" style="color: var(--text-dim);">
        For Claude Code use <code>claude mcp add misp ... -- misp-mcp</code>. The repo README
        also documents OpenClaw, Codex CLI, Hermes Agent, and Docker.
      </p>
    </section>

    <!-- ============================ CAPABILITIES ============================ -->
    <section class="mb-10">
      <div class="section-rule mb-5"><h2 class="kicker m-0">CAPABILITIES / TOOLS EXPOSED</h2></div>
      <p class="max-w-2xl mb-6" style="color: var(--text-muted);">
        36 MCP tools across events, attributes, correlation, exports, tags, objects, galaxies,
        feeds, and server admin. Grouped below; see the README for the full per-argument
        reference.
      </p>
      {toolGroups.map((g) => (
        <>
          <p class="cap-group-label">{g.group}</p>
          <div class="cap-list">
            {g.tools.map((t) => (
              <div class="cap">
                <div class="cap-name">{t.name}</div>
                <div class="cap-desc">{t.desc}</div>
              </div>
            ))}
          </div>
        </>
      ))}
      <p class="text-sm mt-6 max-w-2xl" style="color: var(--text-dim);">
        Plus 3 resources (<code>misp://types</code>, <code>misp://statistics</code>,
        <code>misp://taxonomies</code>) and 3 prompts (investigate-ioc, create-incident-event,
        threat-report).
      </p>
    </section>

    <!-- ============================ SPEC STRIP ============================ -->
    <section class="mb-10">
      <div class="spec-strip">
        <div class="spec"><div class="n">36</div><div class="l">MCP tools</div></div>
        <div class="spec"><div class="n">3</div><div class="l">resources</div></div>
        <div class="spec"><div class="n">3</div><div class="l">prompts</div></div>
        <div class="spec"><div class="n">MIT</div><div class="l">license</div></div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .tool-page code {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.88em;
    color: var(--text);
  }
</style>
